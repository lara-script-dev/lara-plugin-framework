<?xml version="1.0"?>
<psalm
    errorLevel="1"
    phpVersion="8.1"
    resolveFromConfigFile="true"
    cacheDirectory="build/psalm/cache"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://getpsalm.com/schema/config vendor/vimeo/psalm/config.xsd"
>
    <projectFiles>
        <directory name="app" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>
    <issueHandlers>
        <UnusedClass errorLevel="suppress" />
        <PossiblyUnusedMethod errorLevel="suppress" />
    </issueHandlers>
</psalm>
